# =============================
# DevLogger Environment Example
# =============================

# ---------- Backend ----------
PORT=5500
MONGODB_URL=mongodb:
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
FRONTEND_ORIGIN=http:

# Optional security tuning
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MINUTES=15

# ---------- Frontend (Vite at Frontend/ folder) ----------
# Create Frontend/.env.local and set the below (Vite only exposes VITE_*)
VITE_API_URL=http://localhost:5500/api/v1/

# ---------- Notes ----------
# - Never commit your real JWT_SECRET to version control.
# - For production, point MONGODB_URL to a managed cluster and rotate secrets.
# - FRONTEND_ORIGIN must match the deployed frontend URL for CORS.
